{
  "env": {
    "es2021": true,
    "node": true,
    "browser": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "ignorePatterns": ["node_modules/", "dist/", "build/"],
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error"
  }
}
